.env

# Ignore build output
.svelte-kit/
build/

# Windows metadata files
*.Zone.Identifier
*.jpg
*.png

# Allow PWA icons (required for PWA installability)
!static/icons/*.png

# Allow iOS home-screen icons (#101)
!static/apple-touch-icon*.png

# Allow the shared hero banner (optimized JPEG, #121)
!static/Jax-Banner.jpg
